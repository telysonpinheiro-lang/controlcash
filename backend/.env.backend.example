# Configuração WhatsApp — Evolution API (self-hosted gratuito)
# Docs: https://doc.evolution-api.com/
#
# 1. Instale a Evolution API: docker run -d -p 8080:8080 atendai/evolution-api:latest
# 2. Acesse http://localhost:8080/manager, crie uma instância e conecte o QR Code
# 3. Preencha abaixo e renomeie este arquivo para .env.backend

WA_API_URL=http://localhost:8080
WA_API_TOKEN=sua_apikey_aqui
WA_INSTANCE=virtualcore
